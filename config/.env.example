# ====== Grok / xAI ======
# Отримати тут: https://console.x.ai
XAI_API_KEY=

# ====== CoinGecko ======
# Demo-ключ (безкоштовний, 30 req/min): https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=
# Якщо ключ платний — змінити base URL у crypto_monitor/data_sources.py

# ====== Polymarket ======
# Для read-only аналітики ключі НЕ потрібні.
# Для трейдингу потрібен PRIVATE_KEY гаманця на Polygon (chain_id=137).
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# Polymarket заблокований в Україні з січня 2026 — потрібен проксі.
# Формати: http://user:pass@host:port, socks5://host:port
# Можна також просто експортувати HTTPS_PROXY.
POLYMARKET_PROXY=

# ====== Telegram-нотифікації ======
# Створи бота: @BotFather → /newbot, візьми token
# chat_id: напиши боту, потім https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ====== Інше ======
LOG_LEVEL=INFO
TIMEZONE=Europe/Kyiv
